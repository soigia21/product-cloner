{% liquid
  assign metafield_template_id = product.metafields.personalizer.template_id.value
  if metafield_template_id == blank
    assign metafield_template_id = product.metafields.personalizer.template_id
  endif
%}

<div
  class="pz-theme-block"
  data-personalizer-block
  data-template-id="{{ metafield_template_id | escape }}"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle | escape }}"
  data-app-base-url="{{ block.settings.app_base_url | escape }}"
  data-show-debug="{{ block.settings.show_debug }}"
>
  <h1 class="pz-theme-title">Personalized</h1>
</div>

<style>
  .pz-theme-block {
    --pz-bg: #f7f3ee;
    --pz-surface: #ffffff;
    --pz-border: #e0d8cc;
    --pz-text: #1a1a1a;
    width: 100%;
    margin: 0 0 24px 0;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--pz-text);
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
  }
  .pz-theme-title {
    margin: 0 0 12px;
    text-align: center;
    font-size: 24px;
    line-height: 1.2;
    font-weight: 700;
    color: inherit;
    font-family: Harmond, serif;
  }
  .pz-debug {
    margin-top: 12px;
    font-size: 13px;
    line-height: 1.5;
    color: #555;
    white-space: pre-wrap;
    word-break: break-word;
    background: var(--pz-surface);
    border: 1.5px solid var(--pz-border);
    border-radius: 16px;
    padding: 12px;
  }
  .pz-embed-shell {
    width: 100%;
    margin: 0;
    border: 0;
    border-radius: 0;
    overflow: visible;
    background: transparent;
  }
  .pz-embed-frame {
    width: 100%;
    border: 0;
    display: block;
    background: transparent;
    overflow: visible;
  }
  .pz-main-edit-bar[hidden] {
    display: none !important;
  }
  .pz-main-edit-bar {
    position: absolute;
    left: 50%;
    bottom: 12px;
    transform: translateX(-50%);
    z-index: 90;
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
    padding: 8px 10px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(0, 0, 0, 0.12);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }
  .pz-main-edit-row {
    display: flex;
    flex-wrap: nowrap;
    gap: 6px;
    align-items: center;
    justify-content: center;
  }
  .pz-main-edit-btn {
    min-width: 34px;
    height: 34px;
    padding: 0 10px;
    border-radius: 9px;
    border: 1px solid rgba(0, 0, 0, 0.14);
    background: #fff;
    color: #171717;
    font-size: 16px;
    font-weight: 600;
    line-height: 1;
    cursor: pointer;
  }
  .pz-main-edit-btn.is-arrow {
    font-size: 18px;
    font-weight: 700;
  }
  .pz-main-edit-btn:hover {
    border-color: #111;
  }
  .pz-main-edit-state {
    font-size: 11px;
    color: #4b5563;
    line-height: 1.2;
    text-align: center;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .pz-theme-block {
      margin-bottom: 20px;
    }
    .pz-main-edit-bar {
      max-width: calc(100vw - 24px);
      overflow-x: auto;
    }
  }
</style>

<script src="{{ 'personalizer-block.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Personalizer Block",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "text",
      "id": "app_base_url",
      "label": "Fallback app URL",
      "default": "https://product-cloner.groupaliens.com",
      "info": "Domain running Product Cloner app, for example: https://product-cloner.groupaliens.com"
    },
    {
      "type": "checkbox",
      "id": "show_debug",
      "label": "Show debug summary",
      "default": false
    }
  ]
}
{% endschema %}
